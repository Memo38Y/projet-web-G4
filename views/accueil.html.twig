{% extends 'layout.html.twig' %}

{% block title %}Accueil - Web4All{% endblock %}

{% block content %}
    <section class="hero">
        <h1>Trouve le job qui te correspond</h1>
        <p>Des milliers d'offres de stage disponibles</p>
        <div class="search-box">
            <input type="text" id="job" placeholder="Métier">
            <input type="text" id="city" placeholder="Ville">
            <button>Rechercher</button>
        </div>
    </section>

    <section class="categories">
        <h2>Catégories populaires</h2>
        <div class="grid">
            <div class="category">💻 Informatique</div>
            <div class="category">📈 Marketing</div>
            <div class="category">🏥 Santé</div>
        </div>
    </section>

    <section class="jobs">
        <h2>Dernières offres</h2>
        
        {% for offre in dernieresOffres %}
            <div class="job-card">
                <h3>{{ offre.titre }}</h3>
                {% if session.user.role == 1 %}
                    
                    {% if offre.Id_OFFRE in mesFavorisIds %}
                        {% set couleur_drapeau = '#2a6df4' %} {% else %}
                        {% set couleur_drapeau = '#ccc' %}     {% endif %}

                    <span class="favori-flag" data-id="{{ offre.Id_OFFRE }}" onclick="toggleFavori(this)" 
                          style="cursor: pointer; color: {{ couleur_drapeau }}; font-size: 24px; float: right; transition: 0.3s;">
                        ⚑
                    </span>
                    
                {% endif %}
                <div class="job-details">
                    <span class="badge location">{{ offre.lieu }}</span>
                    <span class="badge contract">{{ offre.type_contrat }}</span>
                    <span class="badge salary">{{ offre.base_remuneration }} €</span>
                </div>
                <button>Voir l'offre</button>
            </div>
        {% else %}
            <p style="text-align:center;">Aucune offre disponible pour le moment.</p>
        {% endfor %}
    </section>

    <div id="toast" style="visibility: hidden; min-width: 250px; background-color: #2a6df4; color: #fff; text-align: center; border-radius: 8px; padding: 16px; position: fixed; z-index: 1; left: 50%; bottom: 30px; transform: translateX(-50%); box-shadow: 0px 4px 10px rgba(0,0,0,0.2); transition: 0.5s;">
        Offre ajoutée aux favoris !
    </div>

    <script>
    function toggleFavori(element) {
        const offreId = element.getAttribute('data-id');
        
        // On envoie la requête silencieuse au contrôleur PHP
        fetch('/api/favori/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id_offre=' + offreId
        })
        .then(response => response.json())
        .then(data => {
            const toast = document.getElementById("toast");
            
            if(data.status === 'added') {
                element.style.color = '#2a6df4'; // Devient bleu !
                toast.innerText = "⭐ Offre ajoutée à vos favoris !";
            } else if(data.status === 'removed') {
                element.style.color = '#ccc'; // Redevient gris
                toast.innerText = "❌ Offre retirée des favoris.";
            }
            
            // On affiche le pop-up pendant 3 secondes
            toast.style.visibility = "visible";
            toast.style.bottom = "50px";
            setTimeout(() => { 
                toast.style.visibility = "hidden"; 
                toast.style.bottom = "30px";
            }, 3000);
        });
    }
    </script>
{% endblock %}