{% extends 'layout.html.twig' %}

{% block title %}Accueil - Web4All{% endblock %}

{% block content %}
    <section class="hero">
        <h1>Trouve le job qui te correspond</h1>
        <p>Des milliers d'offres de stage disponibles</p>
        <div class="search-box">
            <input type="text" id="job" placeholder="Métier">
            <input type="text" id="city" placeholder="Ville">
            <button>Rechercher</button>
        </div>
    </section>

    <section class="statistics" style="margin: 40px auto; max-width: 900px; text-align: center; position: relative;">
        <h2 style="color: #1e2a3a; margin-bottom: 20px;">📊 Le marché en temps réel</h2>
        
        <button id="btn-prev" style="position: absolute; left: -20px; top: 55%; transform: translateY(-50%); background: #2a6df4; color: white; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; font-size: 1.2em; z-index: 10; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">❮</button>
        <button id="btn-next" style="position: absolute; right: -20px; top: 55%; transform: translateY(-50%); background: #2a6df4; color: white; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; font-size: 1.2em; z-index: 10; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">❯</button>

        <div id="stats-track" style="display: flex; gap: 20px; overflow-x: auto; scroll-snap-type: x mandatory; padding: 10px 5px; scrollbar-width: none; -ms-overflow-style: none;">
            
            <div style="min-width: 250px; flex: 0 0 auto; scroll-snap-align: center; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eef2f9;">
                <div style="font-size: 2.5em; margin-bottom: 10px;">💼</div>
                <h3 style="color: #2a6df4; font-size: 2.2em; margin: 0;">{{ stats.total_offres }}</h3>
                <p style="color: #555; margin-top: 10px; font-weight: 600;">Offres en base</p>
            </div>

            <div style="min-width: 250px; flex: 0 0 auto; scroll-snap-align: center; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eef2f9;">
                <div style="font-size: 2.5em; margin-bottom: 10px;">⏱️</div>
                <h3 style="color: #ff6b35; font-size: 1.5em; margin: 0;">Répartition</h3>
                <p style="color: #555; margin-top: 10px; font-weight: 600; font-size: 0.9em;">
                    {{ stats.repartition }}
                </p>
            </div>

            <div style="min-width: 250px; flex: 0 0 auto; scroll-snap-align: center; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eef2f9;">
                <div style="font-size: 2.5em; margin-bottom: 10px;">🏆</div>
                <h3 style="color: #d49a11; font-size: 1.5em; margin: 0;">Top Favoris</h3>
                <p style="color: #555; margin-top: 10px; font-weight: 600; font-size: 0.9em; line-height: 1.4;">
                    {{ stats.top_wishlist }}
                </p>
            </div>

            <div style="min-width: 250px; flex: 0 0 auto; scroll-snap-align: center; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #eef2f9;">
                <div style="font-size: 2.5em; margin-bottom: 10px;">📈</div>
                <h3 style="color: #28a745; font-size: 2.2em; margin: 0;">{{ stats.moyenne_candidatures }}</h3>
                <p style="color: #555; margin-top: 10px; font-weight: 600;">Candidatures / Offre</p>
            </div>

        </div>
    </section>

    <style>
        #stats-track::-webkit-scrollbar { display: none; }
    </style>

    <script>
        document.addEventListener("DOMContentLoaded", function() {
            const track = document.getElementById('stats-track');
            const btnNext = document.getElementById('btn-next');
            const btnPrev = document.getElementById('btn-prev');
            const scrollAmount = 270; // Largeur de défilement (1 carte + l'écart)

            btnNext.addEventListener('click', () => {
                track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
            });

            btnPrev.addEventListener('click', () => {
                track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
            });
        });
    </script>
    <section class="categories">
        <h2>Catégories populaires</h2>
        <div class="grid">
            <div class="category">💻 Informatique</div>
            <div class="category">📈 Marketing</div>
            <div class="category">🏥 Santé</div>
        </div>
    </section>

    <section class="jobs">
        <h2>Dernières offres</h2>
        
        {% for offre in dernieresOffres %}
            <div class="job-card">
                <h3>{{ offre.titre }}</h3>
                
                {% if session.user.role == 1 %}
                    {% if offre.Id_OFFRE in mesFavorisIds %}
                        {% set couleur_drapeau = '#2a6df4' %} 
                    {% else %}
                        {% set couleur_drapeau = '#ccc' %}     
                    {% endif %}

                    <span class="favori-flag" data-id="{{ offre.Id_OFFRE }}" onclick="toggleFavori(this)" 
                          style="cursor: pointer; color: {{ couleur_drapeau }}; font-size: 24px; float: right; transition: 0.3s;">
                        ⚑
                    </span>
                {% endif %}
                
                <div class="job-details">
                    <span class="badge location">{{ offre.lieu }}</span>
                    <span class="badge contract">{{ offre.type_contrat }}</span>
                    <span class="badge salary">{{ offre.base_remuneration }} €</span>
                </div>
                
                <a href="/offre?id={{ offre.Id_OFFRE }}">
                    <button style="margin-top: 15px;">Voir l'offre</button>
                </a>
            </div>
        {% else %}
            <p style="text-align:center;">Aucune offre disponible pour le moment.</p>
        {% endfor %}
    </section>
{% endblock %}