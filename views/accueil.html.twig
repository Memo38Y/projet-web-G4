{% extends 'layout.html.twig' %}

{% block title %}Accueil - Web4All{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="/css/style.css">
{% endblock %}

{% block content %}
    <section class="hero">
        <h1>Trouve le job qui te correspond</h1>
        <p>Des milliers d'offres de stage disponibles</p>
        <div class="search-box">
            <input type="text" id="job" placeholder="Métier">
            <input type="text" id="city" placeholder="Ville">
            <button>Rechercher</button>
        </div>
    </section>

    <section class="statistics">
        <h2>📊 Le marché en temps réel</h2>

        <div class="slider-container">
            <div class="slider-track">

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">💼</div>
                    <h3 style="color: #2a6df4; font-size: 2.2em; margin: 0;">{{ stats.total_offres }}</h3>
                    <p>Offres en base</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">⏱️</div>
                    <h3 style="color: #ff6b35; font-size: 1.5em; margin: 0;">Répartition</h3>
                    <p>{{ stats.repartition }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">🏆</div>
                    <h3 style="color: #d49a11; font-size: 1.5em; margin: 0;">Top Favoris</h3>
                    <p>{{ stats.top_wishlist }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">📈</div>
                    <h3 style="color: #28a745; font-size: 2.2em; margin: 0;">{{ stats.moyenne_candidatures }}</h3>
                    <p>Candidatures / Offre</p>
                </div>

                {# Clones pour l'effet de boucle infinie #}
                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">💼</div>
                    <h3 style="color: #2a6df4; font-size: 2.2em; margin: 0;">{{ stats.total_offres }}</h3>
                    <p>Offres en base</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">⏱️</div>
                    <h3 style="color: #ff6b35; font-size: 1.5em; margin: 0;">Répartition</h3>
                    <p>{{ stats.repartition }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">🏆</div>
                    <h3 style="color: #d49a11; font-size: 1.5em; margin: 0;">Top Favoris</h3>
                    <p>{{ stats.top_wishlist }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">📈</div>
                    <h3 style="color: #28a745; font-size: 2.2em; margin: 0;">{{ stats.moyenne_candidatures }}</h3>
                    <p>Candidatures / Offre</p>
                </div>

            </div>
        </div>
    </section>

    <section class="categories">
        <h2>Catégories populaires</h2>
        <div class="grid">
            <div class="category">💻 Informatique</div>
            <div class="category">📈 Marketing</div>
            <div class="category">🏥 Santé</div>
        </div>
    </section>

    <section class="jobs">
        <h2>Toutes nos offres</h2>
        <p>Fais défiler vers le bas pour découvrir toutes nos opportunités ! 👇</p>

        {% for offre in offres %}
            <div class="job-card">
                <h3>{{ offre.titre }}</h3>

                {% if session.user.role == 1 %}
                    <span class="favori-flag"
                          data-id="{{ offre.Id_OFFRE }}"
                          onclick="toggleFavori(this)"
                          style="color: {{ offre.Id_OFFRE in mesFavorisIds ? '#3b3fb5' : '#ccc' }};">
                        ⚑
                    </span>
                {% endif %}

                <div class="job-details">
                    <span class="badge location">{{ offre.lieu }}</span>
                    <span class="badge contract">{{ offre.type_contrat }}</span>
                    <span class="badge salary">{{ offre.base_remuneration }} €</span>
                </div>

                <a href="/offre?id={{ offre.Id_OFFRE }}">
                    <button>Voir l'offre</button>
                </a>
            </div>
        {% else %}
            <div class="empty-state">
                <p>Aucune offre n'est disponible pour le moment.</p>
            </div>
        {% endfor %}
    </section>
{% endblock %}
