{% extends 'layout.html.twig' %}

{% block title %}Accueil - Web4All{% endblock %}

{% block content %}
    <section class="hero">
        <h1>Trouve le job qui te correspond</h1>
        <p>Des milliers d'offres de stage disponibles</p>
        <div class="search-box">
            <input type="text" id="job" placeholder="Métier">
            <input type="text" id="city" placeholder="Ville">
            <button>Rechercher</button>
        </div>
    </section>

    <section class="statistics" style="margin: 40px auto; max-width: 900px; text-align: center; overflow: hidden;">
        <h2 style="color: #1e2a3a; margin-bottom: 20px;">📊 Le marché en temps réel</h2>
        
        <div class="slider-container" style="position: relative; width: 100%; overflow: hidden; padding: 10px 0;">
            <div class="slider-track">
                
                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">💼</div>
                    <h3 style="color: #2a6df4; font-size: 2.2em; margin: 0;">{{ stats.total_offres }}</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600;">Offres en base</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">⏱️</div>
                    <h3 style="color: #ff6b35; font-size: 1.5em; margin: 0;">Répartition</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600; font-size: 0.9em;">{{ stats.repartition }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">🏆</div>
                    <h3 style="color: #d49a11; font-size: 1.5em; margin: 0;">Top Favoris</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600; font-size: 0.9em; line-height: 1.4;">{{ stats.top_wishlist }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">📈</div>
                    <h3 style="color: #28a745; font-size: 2.2em; margin: 0;">{{ stats.moyenne_candidatures }}</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600;">Candidatures / Offre</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">💼</div>
                    <h3 style="color: #2a6df4; font-size: 2.2em; margin: 0;">{{ stats.total_offres }}</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600;">Offres en base</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">⏱️</div>
                    <h3 style="color: #ff6b35; font-size: 1.5em; margin: 0;">Répartition</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600; font-size: 0.9em;">{{ stats.repartition }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">🏆</div>
                    <h3 style="color: #d49a11; font-size: 1.5em; margin: 0;">Top Favoris</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600; font-size: 0.9em; line-height: 1.4;">{{ stats.top_wishlist }}</p>
                </div>

                <div class="slide-card">
                    <div style="font-size: 2.5em; margin-bottom: 10px;">📈</div>
                    <h3 style="color: #28a745; font-size: 2.2em; margin: 0;">{{ stats.moyenne_candidatures }}</h3>
                    <p style="color: #555; margin-top: 10px; font-weight: 600;">Candidatures / Offre</p>
                </div>

            </div>
        </div>
    </section>

    <style>
        .slider-track {
            display: flex;
            gap: 20px;
            /* La piste fait 2 fois la taille nécessaire pour accueillir les originaux + les clones */
            width: calc((250px + 20px) * 8); 
            animation: scroll 15s linear infinite;
        }

        /* Pause le défilement si l'utilisateur met sa souris dessus ! */
        .slider-track:hover {
            animation-play-state: paused;
        }

        .slide-card {
            width: 250px;
            flex: 0 0 auto;
            background: white;
            padding: 25px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            border: 1px solid #eef2f9;
        }

        @keyframes scroll {
            0% {
                transform: translateX(0);
            }
            100% {
                /* On se décale vers la gauche exactement de la taille des 4 premières cartes */
                transform: translateX(calc(-270px * 4));
            }
        }
    </style>
    <section class="categories">
        <h2>Catégories populaires</h2>
        <div class="grid">
            <div class="category">💻 Informatique</div>
            <div class="category">📈 Marketing</div>
            <div class="category">🏥 Santé</div>
        </div>
    </section>

    <section class="jobs" style="margin-top: 40px;">
        <h2>Toutes nos offres</h2>
        <p style="text-align: center; color: #555; margin-bottom: 30px;">Fais défiler vers le bas pour découvrir toutes nos opportunités ! 👇</p>
        
        {% for offre in offres %}
            <div class="job-card">
                <h3>{{ offre.titre }}</h3>
                
                {% if session.user.role == 1 %}
                    {% if offre.Id_OFFRE in mesFavorisIds %}
                        {% set couleur_drapeau = '#2a6df4' %} 
                    {% else %}
                        {% set couleur_drapeau = '#ccc' %}     
                    {% endif %}

                    <span class="favori-flag" data-id="{{ offre.Id_OFFRE }}" onclick="toggleFavori(this)" 
                          style="cursor: pointer; color: {{ couleur_drapeau }}; font-size: 24px; float: right; transition: 0.3s;">
                        ⚑
                    </span>
                {% endif %}
                
                <div class="job-details">
                    <span class="badge location">{{ offre.lieu }}</span>
                    <span class="badge contract">{{ offre.type_contrat }}</span>
                    <span class="badge salary">{{ offre.base_remuneration }} €</span>
                </div>
                
                <a href="/offre?id={{ offre.Id_OFFRE }}">
                    <button style="margin-top: 15px;">Voir l'offre</button>
                </a>
            </div>
        {% else %}
            <div style="background: #f5f7fb; padding: 20px; border-radius: 8px; text-align: center; margin-top: 20px;">
                <p style="color: #555; font-size: 1.1em;">Aucune offre n'est disponible pour le moment.</p>
            </div>
        {% endfor %}
    </section>
{% endblock %}