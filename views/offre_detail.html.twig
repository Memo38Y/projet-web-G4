{% extends 'layout.html.twig' %}

{% block title %}{{ offre.titre }} - Web4All{% endblock %}

{% block content %}
    <section class="hero" style="padding: 40px 20px; text-align: left; display: flex; justify-content: space-between; align-items: center; max-width: 800px; margin: 0 auto;">
        <div>
            <h1 style="margin-bottom: 5px;">{{ offre.titre }}</h1>
            <p style="font-size: 1.2em; opacity: 0.9;">
                Proposé par 
                
                <a href="/entreprise_offres?id={{ offre.Id_ENTREPRISE }}" style="position: relative; z-index: 10; color: #ffffff; text-decoration: none; transition: 0.2s; padding: 2px 5px; border-radius: 4px; background: #2a6df4;" onmouseover="this.style.background='#1e2a3a'" onmouseout="this.style.background='#2a6df4'">
                    <strong>{{ offre.nom_entreprise }}</strong>
                </a>
                
            </p>
        </div>
        
        {% if session.user.role == 1 %}
            {% set couleur_drapeau = estFavori ? '#2a6df4' : '#ccc' %}
            <span class="favori-flag" data-id="{{ offre.Id_OFFRE }}" onclick="toggleFavori(this)" 
                  style="cursor: pointer; color: {{ couleur_drapeau }}; font-size: 36px; transition: 0.3s; background: white; padding: 10px 15px; border-radius: 50%; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
                ⚑
            </span>
        {% endif %}
    </section>

    <section class="categories" style="display: flex; justify-content: center; padding: 40px 20px;">
        <div class="job-card" style="width: 100%; max-width: 800px; text-align: left;">
            
            <div style="display: flex; gap: 10px; margin-bottom: 25px; flex-wrap: wrap;">
                <span class="badge location">📍 {{ offre.lieu }}</span>
                <span class="badge contract">💶 {{ offre.base_remuneration }} € / mois</span>
                {% if offre.duree %}
                    <span class="badge" style="background: #eef2f9; color: #1e2a3a; padding: 5px 12px; border-radius: 20px; font-size: 0.85em; font-weight: 600;">⏱️ {{ offre.duree }}</span>
                {% endif %}
                <span class="badge" style="background: #eef2f9; color: #1e2a3a; padding: 5px 12px; border-radius: 20px; font-size: 0.85em; font-weight: 600;">👥 {{ offre.places_disponibles }} place(s)</span>
            </div>

            <h3 style="color: #2a6df4; border-bottom: 2px solid #eef2f9; padding-bottom: 10px;">Description du stage</h3>
            <p style="line-height: 1.6; color: #444; margin-bottom: 30px;">{{ offre.description }}</p>

            <h3 style="color: #2a6df4; border-bottom: 2px solid #eef2f9; padding-bottom: 10px;">Compétences requises</h3>
            {% if competences is not empty %}
                <div style="display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 30px; margin-top: 15px;">
                    {% for comp in competences %}
                        <span style="background: #1e2a3a; color: white; padding: 6px 15px; border-radius: 6px; font-size: 0.9em;">{{ comp }}</span>
                    {% endfor %}
                </div>
            {% else %}
                <p>Aucune compétence spécifique n'a été renseignée pour cette offre.</p>
            {% endif %}

            <div style="text-align: center; margin-top: 40px; border-top: 1px solid #eef2f9; padding-top: 25px;">
                {% if session.user %}
                    {% if session.user.role == 1 %}
                        
                        {% if aDejaPostule %}
                            <div style="background: #eef2f9; border: 1px solid #2a6df4; border-radius: 8px; padding: 25px; text-align: center; margin-top: 25px; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                                <h4 style="color: #2a6df4; margin-top: 0; margin-bottom: 10px; font-size: 1.2em;">✅ Tu as déjà postulé à cette offre !</h4>
                                <p style="color: #555; margin-bottom: 20px;">L'entreprise a bien reçu ton CV et ta lettre de motivation.</p>
                                
                                <form action="/candidature/supprimer" method="POST" style="margin: 0;">
                                    <input type="hidden" name="id_offre" value="{{ offre.Id_OFFRE }}">
                                    <button type="submit" onclick="return confirm('Es-tu sûr de vouloir annuler ta candidature pour cette offre ?');" style="background: #dc3545; color: white; padding: 10px 25px; border: none; border-radius: 6px; font-weight: bold; cursor: pointer; transition: 0.2s;">
                                        Annuler ma candidature
                                    </button>
                                </form>
                            </div>
                        
                        {% else %}
                            <button onclick="document.getElementById('form-postuler').style.display='block'" style="font-size: 1.1em; padding: 12px 30px; background: #28a745; border: none; color: white; cursor: pointer; border-radius: 6px; font-weight: bold;">
                                🚀 Je postule à cette offre
                            </button>

                            <form id="form-postuler" action="/postuler" method="POST" enctype="multipart/form-data" style="display: none; margin-top: 25px; background: #fdfaf6; padding: 25px; border-radius: 8px; border: 1px solid #f9eac5; text-align: left; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                                
                                <input type="hidden" name="id_offre" value="{{ offre.Id_OFFRE }}">
                                
                                <h4 style="color: #d49a11; margin-top: 0; margin-bottom: 15px; border-bottom: 1px solid #f9eac5; padding-bottom: 10px;">📄 Ma candidature</h4>

                                <div style="margin-bottom: 15px;">
                                    <label style="font-weight: bold; display: block; margin-bottom: 5px; color: #1e2a3a;">Mon CV (Format PDF uniquement) *</label>
                                    <input type="file" name="cv" accept=".pdf" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; background: white;">
                                </div>
                                
                                <div style="margin-bottom: 15px;">
                                    <label style="font-weight: bold; display: block; margin-bottom: 5px; color: #1e2a3a;">Lettre de motivation *</label>
                                    <textarea name="motivation" rows="5" placeholder="Expliquez à l'entreprise pourquoi vous êtes le candidat idéal pour ce poste..." required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px; resize: vertical;"></textarea>
                                </div>
                                
                                <div style="display: flex; gap: 10px; justify-content: center; margin-top: 20px;">
                                    <button type="submit" style="background: #2a6df4; color: white; padding: 10px 25px; border: none; border-radius: 4px; font-weight: bold; cursor: pointer;">Envoyer ma candidature</button>
                                    <button type="button" onclick="document.getElementById('form-postuler').style.display='none'" style="background: #6c757d; color: white; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">Annuler</button>
                                </div>
                            </form>
                        {% endif %}

                    {% else %}
                        <p style="color: #888;"><em>Connecté en tant que {{ session.user.role == 2 ? 'Pilote' : (session.user.role == 3 ? 'Administrateur') }}. Seuls les étudiants peuvent postuler.</em></p>
                    {% endif %}
                {% else %}
                    <p style="margin-bottom: 15px;">Connectez-vous pour postuler à cette offre.</p>
                    <a href="/connexion"><button style="background: #1e2a3a;">Se connecter</button></a>
                {% endif %}
            </div>

        </div>
    </section>
{% endblock %}