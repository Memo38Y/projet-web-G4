{% extends 'layout.html.twig' %}

{% block title %}Nos Entreprises - Web4All{% endblock %}

{% block content %}
    <section class="hero">
        <h1>Découvrez nos entreprises partenaires</h1>
        <p>Trouvez la structure idéale pour votre stage</p>
        
        <form action="/entreprises" method="GET" class="search-box">
            <input type="text" name="q" placeholder="Nom de l'entreprise, secteur..." value="{{ search_q }}">
            <button type="submit">Rechercher</button>
        </form>
    </section>

    <section class="jobs">
        <h2>Les entreprises qui recrutent</h2>
        
        {% if search_q %}
            <div style="text-align: center; margin-bottom: 30px; background: #fff3ed; padding: 15px; border-radius: 8px; border: 1px solid #f9eac5; display: inline-block; position: relative; left: 50%; transform: translateX(-50%);">
                <p style="color: #d49a11; font-size: 1.1em; margin: 0 0 10px 0;">
                    🔍 Résultats pour : <strong>"{{ search_q }}"</strong>
                </p>
                <a href="/entreprises" style="display: inline-block; color: white; background: #ff6b35; padding: 5px 15px; border-radius: 4px; text-decoration: none; font-weight: bold; font-size: 0.85em; transition: 0.2s;">
                    ✖ Effacer la recherche
                </a>
            </div>
        {% endif %}
        
        {% for entreprise in entreprises %}
            <div class="job-card">
                <h3>{{ entreprise.nom }}</h3>
                
                <p>{{ entreprise.description }}</p>
                
                <div class="job-details">
                    <span class="badge location">{{ entreprise.secteur_activite | default('Secteur non précisé') }}</span>
                    <span class="badge contract">{{ entreprise.email_contact }}</span>
                </div>
                
                <a href="/entreprise_offres?id={{ entreprise.Id_ENTREPRISE }}">
                    <button style="margin-top: 15px;">Voir les offres de cette entreprise</button>
                </a>
            </div>
        {% else %}
            <div style="background: #f5f7fb; padding: 30px; border-radius: 8px; text-align: center; margin-top: 20px;">
                <h3 style="color: #ff6b35; margin-bottom: 10px;">Oups ! 😕</h3>
                <p style="color: #555; font-size: 1.1em; margin-bottom: 15px;">Aucune entreprise ne correspond à cette recherche.</p>
                <a href="/entreprises">
                    <button style="background: #1e2a3a; padding: 10px 20px;">Voir toutes les entreprises</button>
                </a>
            </div>
        {% endfor %}

        {% if totalPages > 1 %}
            <div style="display: flex; justify-content: center; gap: 10px; margin-top: 50px; flex-wrap: wrap;">
                
                {% if currentPage > 1 %}
                    <a href="/entreprises?q={{ search_q }}&p={{ currentPage - 1 }}" style="position: relative; z-index: 9999; padding: 10px 15px; border-radius: 6px; text-decoration: none; background: #eef2f9; color: #1e2a3a; font-weight: bold; transition: 0.2s;">
                        &laquo; Précédent
                    </a>
                {% endif %}

                {% for p in 1..totalPages %}
                    <a href="/entreprises?q={{ search_q }}&p={{ p }}" 
                       style="position: relative; z-index: 9999; padding: 10px 18px; border-radius: 6px; text-decoration: none; font-weight: bold; transition: 0.2s;
                              background: {{ p == currentPage ? '#2a6df4' : '#eef2f9' }}; 
                              color: {{ p == currentPage ? 'white' : '#1e2a3a' }};">
                        {{ p }}
                    </a>
                {% endfor %}

                {% if currentPage < totalPages %}
                    <a href="/entreprises?q={{ search_q }}&p={{ currentPage + 1 }}" style="position: relative; z-index: 9999; padding: 10px 15px; border-radius: 6px; text-decoration: none; background: #eef2f9; color: #1e2a3a; font-weight: bold; transition: 0.2s;">
                        Suivant &raquo;
                    </a>
                {% endif %}
                
            </div>
        {% endif %}

    </section>
{% endblock %}