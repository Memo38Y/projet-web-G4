<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}JobFinder / Web4All{% endblock %}</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
</head>
<body>

    <nav>
        <div class="logo">Web4All</div>
        <ul>
            <li><a href="/">Accueil</a></li>
            <li><a href="/entreprises">Entreprises</a></li>
            {% if session.user %}
                <li><a href="/profil" style="color: #2a6df4; font-weight: bold;">Mon Profil ({{ session.user.prenom }})</a></li>
                <li><a href="/deconnexion">Déconnexion</a></li>
            {% else %}
                <li><a href="/connexion">Connexion</a></li>
            {% endif %}
        </ul>
    </nav>

    <main>
        {% block content %}{% endblock %}
    </main>

    <footer style="text-align: center; padding: 20px; background: #f8f9fa; margin-top: 40px; border-top: 1px solid #eef2f9;">
        <p style="margin: 5px 0; font-weight: bold; color: #1e2a3a;">© 2026 Web4All</p>
        <p style="margin: 5px 0; color: #555;">Trouve ton futur stage facilement</p>
        <p style="margin-top: 15px;">
            <a href="/mentions-legales" style="color: #2a6df4; text-decoration: none; font-size: 0.9em;">Mentions légales</a>
        </p>
    </footer>

    <div id="toast" style="visibility: hidden; min-width: 250px; background-color: #2a6df4; color: #fff; text-align: center; border-radius: 8px; padding: 16px; position: fixed; z-index: 1; left: 50%; bottom: 30px; transform: translateX(-50%); box-shadow: 0px 4px 10px rgba(0,0,0,0.2); transition: 0.5s;">
        Offre ajoutée aux favoris !
    </div>

    <script>
    function toggleFavori(element) {
        const offreId = element.getAttribute('data-id');
        
        // On envoie la requête silencieuse au contrôleur PHP
        fetch('/api/favori/toggle', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id_offre=' + offreId
        })
        .then(response => response.json())
        .then(data => {
            const toast = document.getElementById("toast");
            
            if(data.status === 'added') {
                element.style.color = '#2a6df4'; // Devient bleu !
                toast.innerText = "⭐ Offre ajoutée à vos favoris !";
            } else if(data.status === 'removed') {
                element.style.color = '#ccc'; // Redevient gris
                toast.innerText = "❌ Offre retirée des favoris.";
            }
            
            // On affiche le pop-up pendant 3 secondes
            toast.style.visibility = "visible";
            toast.style.bottom = "50px";
            setTimeout(() => { 
                toast.style.visibility = "hidden"; 
                toast.style.bottom = "30px";
            }, 3000);
        });
    }
    </script>

</body>
</html>
