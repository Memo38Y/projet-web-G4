{% extends 'layout.html.twig' %}

{% block title %}Mes Étudiants - Pilote{% endblock %}

{% block content %}
    <section class="hero" style="padding: 40px 20px;">
        <h1>Ma Promotion</h1>
        <p>Gère la liste de tes étudiants et suis leurs recherches de stage</p>
    </section>

    <section class="categories" style="display: flex; flex-direction: column; align-items: center; gap: 30px; padding: 40px 10%;">
        
        <div style="width: 100%; max-width: 800px; text-align: left;">
             <a href="/profil" style="color: #ff6b35; text-decoration: none; font-weight: bold;">← Retour au profil</a>
             
             {% if message %}
                <div style="background-color: #eef2f9; padding: 15px; border-radius: 6px; margin-top: 20px; text-align: center; font-weight: 600; color: #1e2a3a; border: 1px solid #dfe3ea;">
                    {{ message }}
                </div>
            {% endif %}
        </div>

        <div class="job-card" style="width: 100%; max-width: 800px; text-align: left;">
            <h3 style="color: #2a6df4; border-bottom: 2px solid #eef2f9; padding-bottom: 10px;">➕ Ajouter un étudiant à ma classe</h3>
            <form action="/pilote/etudiants" method="POST" style="display: flex; flex-direction: column; gap: 15px; margin-top: 20px;">
                <input type="hidden" name="action_create" value="1">
                
                <div style="display: flex; gap: 15px;">
                    <div style="flex: 1;">
                        <label style="font-weight: 600;">Nom *</label>
                        <input type="text" name="nom" required maxlength="50" pattern="^[^0-9]+$" title="Pas de chiffres" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                    <div style="flex: 1;">
                        <label style="font-weight: 600;">Prénom *</label>
                        <input type="text" name="prenom" required maxlength="50" pattern="^[^0-9]+$" title="Pas de chiffres" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                </div>
                <div>
                    <label style="font-weight: 600;">Email *</label>
                    <input type="email" name="email" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div>
                    <label style="font-weight: 600;">Mot de passe provisoire *</label>
                    <input type="password" name="password" required maxlength="50" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                
                <button type="submit" style="margin-top: 15px; width: 200px;">Créer l'étudiant</button>
            </form>
        </div>

        <div class="job-card" style="width: 100%; max-width: 800px; text-align: left; border-color: #ff6b35;">
            <h3 style="color: #ff6b35; border-bottom: 2px solid #eef2f9; padding-bottom: 10px;">✏️ Modifier ou Supprimer un de mes étudiants</h3>
            
            <div style="margin-top: 20px; margin-bottom: 20px;">
                <label style="font-weight: 600; color: #ff6b35;">Sélectionner l'étudiant :</label>
                <select id="select-etudiant" style="width: 100%; padding: 12px; margin-top: 5px; border: 2px solid #ff6b35; border-radius: 4px; background: white; font-size: 1.1em;">
                    <option value="">-- Choisir un étudiant dans ma liste --</option>
                    {% for etudiant in etudiants %}
                        <option value="{{ etudiant.Id_Utilisateur }}">{{ etudiant.nom | upper }} {{ etudiant.prenom }}</option>
                    {% endfor %}
                </select>
            </div>

            <form id="form-edit" action="/pilote/etudiants" method="POST" style="display: none; flex-direction: column; gap: 15px; border-top: 1px solid #eef2f9; padding-top: 20px;">
                <input type="hidden" id="edit-id" name="id_utilisateur_edit">

                <div style="display: flex; gap: 15px;">
                    <div style="flex: 1;">
                        <label style="font-weight: 600;">Nom</label>
                        <input type="text" id="edit-nom" name="nom_edit" required maxlength="50" pattern="^[^0-9]+$" title="Pas de chiffres" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                    <div style="flex: 1;">
                        <label style="font-weight: 600;">Prénom</label>
                        <input type="text" id="edit-prenom" name="prenom_edit" required maxlength="50" pattern="^[^0-9]+$" title="Pas de chiffres" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                    </div>
                </div>
                <div>
                    <label style="font-weight: 600;">Email</label>
                    <input type="email" id="edit-email" name="email_edit" required style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                <div>
                    <label style="font-weight: 600;">Nouveau mot de passe (laisser vide pour ne pas changer)</label>
                    <input type="password" name="password_edit" placeholder="••••••••" maxlength="50" style="width: 100%; padding: 10px; border: 1px solid #ccc; border-radius: 4px;">
                </div>
                
                <div style="display: flex; gap: 15px; margin-top: 20px;">
                    <button type="submit" name="action_update" style="flex: 2; background: #ff6b35;">Enregistrer les modifications</button>
                    <button type="submit" name="action_delete" style="flex: 1; background: #dc3545;" onclick="return confirm('⚠️ ATTENTION ⚠️\n\nSupprimer cet étudiant supprimera également toutes ses candidatures et ses favoris.\n\nÊtes-vous sûr de vouloir le supprimer définitivement ?');">Supprimer</button>
                </div>
            </form>
        </div>

        <div class="job-card" style="width: 100%; max-width: 800px; text-align: left; border-color: #28a745;">
            <h3 style="color: #28a745; border-bottom: 2px solid #eef2f9; padding-bottom: 10px;">📊 Suivi des Candidatures de ma promotion</h3>
            
            <p style="color: #555; margin-bottom: 20px;">Voici l'historique des offres auxquelles vos étudiants ont postulé :</p>

            {% if candidaturesPromo is not empty %}
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left; background: white;">
                        <thead>
                            <tr style="background-color: #eef2f9; color: #1e2a3a; border-bottom: 2px solid #ccc;">
                                <th style="padding: 12px; font-weight: bold;">Étudiant</th>
                                <th style="padding: 12px; font-weight: bold;">Offre / Entreprise</th>
                                <th style="padding: 12px; font-weight: bold; text-align: center;">Pièces jointes</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for cand in candidaturesPromo %}
                                <tr style="border-bottom: 1px solid #eef2f9;">
                                    
                                    <td style="padding: 12px; font-weight: 600;">
                                        {{ cand.nom_etudiant | upper }} {{ cand.prenom_etudiant }}
                                    </td>
                                    
                                    <td style="padding: 12px;">
                                        <a href="/offre?id={{ cand.Id_OFFRE }}" style="color: #2a6df4; text-decoration: none; font-weight: bold;" target="_blank">
                                            {{ cand.titre }}
                                        </a><br>
                                        <span style="font-size: 0.9em; color: #555;">🏢 {{ cand.nom_entreprise }}</span>
                                    </td>
                                    
                                    <td style="padding: 12px; text-align: center;">
                                        <div style="display: flex; flex-direction: column; gap: 5px; align-items: center;">
                                            <a href="{{ cand.cv_path }}" target="_blank" style="text-decoration: none;">
                                                <button style="background: #1e2a3a; color: white; border: none; padding: 5px 10px; border-radius: 4px; font-size: 0.85em; cursor: pointer; width: 140px;">
                                                    📄 Voir le CV
                                                </button>
                                            </a>
                                            
                                            <button onclick="alert('Lettre de motivation de {{ cand.prenom_etudiant }} :\n\n{{ cand.lm_path | e('js') }}')" style="background: #ff6b35; color: white; border: none; padding: 5px 10px; border-radius: 4px; font-size: 0.85em; cursor: pointer; width: 140px;">
                                                ✉️ Voir la Lettre
                                            </button>
                                        </div>
                                    </td>
                                    
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div style="background: #f8f9fa; border: 1px dashed #ccc; border-radius: 8px; padding: 25px; text-align: center;">
                    <p style="color: #777; font-size: 1.1em; margin: 0;">Vos étudiants n'ont pas encore envoyé de candidatures.</p>
                </div>
            {% endif %}
        </div>

    </section>

    <script>
        const etudiantsData = {
            {% for etudiant in etudiants %}
                "{{ etudiant.Id_Utilisateur }}": {
                    "nom": "{{ etudiant.nom | e('js') }}",
                    "prenom": "{{ etudiant.prenom | e('js') }}",
                    "email": "{{ etudiant.email | e('js') }}"
                },
            {% endfor %}
        };

        const selector = document.getElementById('select-etudiant');
        const formEdit = document.getElementById('form-edit');

        selector.addEventListener('change', function() {
            const userId = this.value;
            if (userId && etudiantsData[userId]) {
                const data = etudiantsData[userId];
                document.getElementById('edit-id').value = userId;
                document.getElementById('edit-nom').value = data.nom;
                document.getElementById('edit-prenom').value = data.prenom;
                document.getElementById('edit-email').value = data.email;
                formEdit.style.display = 'flex';
            } else {
                formEdit.style.display = 'none';
            }
        });
    </script>
{% endblock %}